# Copy this file to `.env` and fill in real values.
# `.env` is gitignored.

# Mapbox public access token, used for forward geocoding (Phase 1).
# Create one at: https://account.mapbox.com/access-tokens/
# Restrict it to your app's bundle id once Phase 1 ships.
EXPO_PUBLIC_MAPBOX_TOKEN=

# Firebase config (from Firebase Console → Project Settings → Your apps)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
